{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information and status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "status": { "type": "string" },
        "statusEmoji": { "type": "string" },
        "partnerId": { "type": "string", "description": "UID of the linked partner." },
        "coupleId": { "type": "string", "description": "ID of the shared couple document." },
        "lastSeen": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["owner", "member"], "description": "The user's role within the space." },
        "nicknames": { 
          "type": "object", 
          "additionalProperties": { "type": "string" },
          "description": "UID mapping to nicknames set by that user."
        },
        "zodiacSign": { 
          "type": "string", 
          "enum": ["Aries", "Taurus", "Gemini", "Cancer", "Leo", "Virgo", "Libra", "Scorpio", "Sagittarius", "Capricorn", "Aquarius", "Pisces"] 
        },
        "brainBattery": { "type": "integer", "minimum": 0, "maximum": 100, "description": "Mental energy level." },
        "settings": {
          "type": "object",
          "properties": {
             "notifications": { "type": "boolean" },
             "privacy": { "type": "boolean" },
             "atmosphere": { "type": "string", "enum": ["calm", "energetic", "focus"] }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "Couple": {
      "title": "Couple",
      "description": "Shared space settings and state for a couple.",
      "type": "object",
      "properties": {
        "members": { "type": "array", "items": { "type": "string" } },
        "anniversary": { "type": "string", "format": "date" },
        "loveLetterDay": { "type": "integer", "minimum": 0, "maximum": 6, "description": "Day of week for reveal." },
        "quoteOfTheDay": { "type": "object", "properties": {
          "text": { "type": "string" },
          "author": { "type": "string" }
        }},
        "theme": { "type": "string" },
        "lastCosmicInsight": { "type": "string" },
        "lastCosmicSync": { "type": "string", "format": "date-time" },
        "studySession": {
          "type": "object",
          "properties": {
            "isActive": { "type": "boolean" },
            "startTime": { "type": "string", "format": "date-time" },
            "duration": { "type": "integer" },
            "type": { "type": "string", "enum": ["focus", "break"] },
            "startedBy": { "type": "string" }
          }
        }
      },
      "required": ["members"]
    },
    "MusicDedication": {
      "title": "Music Dedication",
      "description": "A song dedicated to the partner.",
      "type": "object",
      "properties": {
        "fromId": { "type": "string" },
        "toId": { "type": "string" },
        "songTitle": { "type": "string" },
        "artist": { "type": "string" },
        "coverUrl": { "type": "string" },
        "songUrl": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fromId", "songTitle", "artist"]
    },
    "Goal": {
      "title": "Goal",
      "description": "A shared or individual goal.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["shared", "individual"] },
        "ownerId": { "type": "string" },
        "coupleId": { "type": "string" },
        "progress": { "type": "number" },
        "deadline": { "type": "string", "format": "date" },
        "completed": { "type": "boolean" }
      },
      "required": ["title", "type", "coupleId"]
    },
    "Plan": {
      "title": "Plan",
      "description": "A scheduled date or event.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["date", "event", "occasion"] },
        "coupleId": { "type": "string" }
      },
      "required": ["title", "date", "coupleId"]
    },
    "Reflection": {
      "title": "Reflection",
      "description": "Weekly love letters shared on a specific day.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "coupleId": { "type": "string" },
        "content": { "type": "string" },
        "weekOf": { "type": "string", "description": "Year and Week identifier." },
        "status": { "type": "string", "enum": ["unread", "read", "responded"] },
        "isFavorited": { "type": "boolean" },
        "response": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "coupleId", "content", "weekOf"]
    },
    "VisionBoardPin": {
      "title": "Vision Board Pin",
      "description": "An image or note on a vision board.",
      "type": "object",
      "properties": {
        "coupleId": { "type": "string" },
        "ownerId": { "type": "string" },
        "boardType": { "type": "string", "enum": ["shared", "individual"] },
        "imageUrl": { "type": "string" },
        "note": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["coupleId", "boardType"]
    },
    "WeeklyActivity": {
      "title": "Weekly Activity",
      "description": "A selected activity for the week.",
      "type": "object",
      "properties": {
        "coupleId": { "type": "string" },
        "title": { "type": "string" },
        "completed": { "type": "boolean" },
        "weekOf": { "type": "string", "format": "date" }
      },
      "required": ["coupleId", "title"]
    },
    "Movie": {
      "title": "Movie",
      "description": "A movie for the couple's watchlist.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "posterUrl": { "type": "string" },
        "year": { "type": "string" },
        "coupleId": { "type": "string" },
        "addedBy": { "type": "string" },
        "watched": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "coupleId"]
    },
    "GalleryItem": {
      "title": "Gallery Item",
      "description": "A shared photo or video in the memory gallery.",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "video"] },
        "addedBy": { "type": "string" },
        "caption": { "type": "string", "description": "Short description for the memory." },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Moods or activities associated with the memory." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["url", "type", "addedBy"]
    },
    "PlaylistItem": {
      "title": "PlaylistItem",
      "description": "A song in the shared couple playlist.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "artist": { "type": "string" },
        "coverUrl": { "type": "string" },
        "songUrl": { "type": "string" },
        "addedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "artist", "addedBy"]
    },
    "Activity": {
      "title": "Activity",
      "description": "A record of an action taken by a member of the couple.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["music", "gallery", "goal", "plan", "reflection", "status", "movie", "nickname"] },
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "userId", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/couples/{coupleId}": {
      "schema": "Couple",
      "description": "Shared couple data."
    },
    "/couples/{coupleId}/musicDedications/{dedicationId}": {
      "schema": "MusicDedication",
      "description": "Song dedications for a couple."
    },
    "/couples/{coupleId}/goals/{goalId}": {
      "schema": "Goal",
      "description": "Goals for the couple or individuals."
    },
    "/couples/{coupleId}/plans/{planId}": {
      "schema": "Plan",
      "description": "Shared calendar/plans."
    },
    "/couples/{coupleId}/reflections/{reflectionId}": {
      "schema": "Reflection",
      "description": "Private reflection space."
    },
    "/couples/{coupleId}/visionBoard/{pinId}": {
      "schema": "VisionBoardPin",
      "description": "Vision board pins."
    },
    "/couples/{coupleId}/weeklyActivities/{activityId}": {
      "schema": "WeeklyActivity",
      "description": "Activities for the week."
    },
    "/couples/{coupleId}/movies/{movieId}": {
      "schema": "Movie",
      "description": "Movie watchlist."
    },
    "/couples/{coupleId}/gallery/{mediaId}": {
      "schema": "GalleryItem",
      "description": "Shared gallery of memories."
    },
    "/couples/{coupleId}/playlist/{songId}": {
      "schema": "PlaylistItem",
      "description": "Shared couple playlist."
    },
    "/couples/{coupleId}/activities/{activityId}": {
      "schema": "Activity",
      "description": "Feed of activities for the couple."
    },
    "/couples/{coupleId}/pokes/{pokeId}": {
      "schema": "object",
      "description": "Neural pokes between partners."
    }
  }
}
