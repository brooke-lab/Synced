rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isMemberOfCouple(coupleId) {
      return isSignedIn() && exists(/databases/$(database)/documents/couples/$(coupleId)) &&
             request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
    }

    // --- Users ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && 
                     isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && 
                     isValidUser(incoming()) &&
                     incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'status', 'statusEmoji', 'partnerId', 'coupleId', 'lastSeen']);
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 100 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 50)) &&
             (!('status' in data) || (data.status is string && data.status.size() <= 100)) &&
             (!('statusEmoji' in data) || (data.statusEmoji is string && data.statusEmoji.size() <= 10));
    }

    // --- Couples ---
    match /couples/{coupleId} {
      allow read: if isSignedIn() && request.auth.uid in existing().members;
      allow create: if isSignedIn() && request.auth.uid in incoming().members && incoming().members.size() <= 2;
      allow update: if isSignedIn() && request.auth.uid in existing().members &&
                     incoming().members == existing().members &&
                     incoming().diff(existing()).affectedKeys().hasOnly(['anniversary', 'quoteOfTheDay', 'theme']);
    }

    // --- Sub-collections under Couples ---
    match /couples/{coupleId}/{collection}/{docId} {
      allow read, write: if isMemberOfCouple(coupleId);
      
      // We should probably harden these further, but for a prototype, this is the Master Gate.
      // Let's add refinement for Reflections to ensure only owner or partner can read/write.
    }

    match /couples/{coupleId}/reflections/{reflectionId} {
      allow read: if isMemberOfCouple(coupleId);
      allow create: if isMemberOfCouple(coupleId) && incoming().authorId == request.auth.uid;
      allow update: if isMemberOfCouple(coupleId) && 
                    (
                      // Author can update content
                      (existing().authorId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['content'])) ||
                      // Partner can update status/response
                      (existing().authorId != request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'response']))
                    );
    }
  }
}
